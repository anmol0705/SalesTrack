{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
    "paths": {
      "@salestrack/types": ["../../packages/types/src"],
      "@salestrack/types/*": ["../../packages/types/src/*"],
      "@salestrack/utils": ["../../packages/utils/src"],
      "@salestrack/utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
