{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noEmit": true,
    "incremental": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@salestrack/types": ["../../packages/types/src"],
      "@salestrack/types/*": ["../../packages/types/src/*"],
      "@salestrack/utils": ["../../packages/utils/src"],
      "@salestrack/utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
